@page
@model MenuModel
@{
    ViewData["Title"] = "Burger Salon";
}

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu</title>
    <link rel="stylesheet" href="~/css/Site.css">
</head>

<body>

<div class="Main-Container">

    <div class="Cart-Sidebar">
        <h2>ההזמנה שלי</h2>
        <div id="cart-items"></div>
        <hr>
        <p>סה"כ: <b id="total-price">0</b> ₪</p>
        
        <input type="text" id="phone" placeholder="מספר טלפון">
        <input type="text" id="address" placeholder="כתובת למשלוח">
        <button class="order-submit" onclick="submitOrder()">בצע הזמנה</button>
    </div>

    <!-- עטיפה לתפריט -->
    <div class="Menu">
        
        <section class="Deals">
            <h1>ארוחות</h1>
            <div class="line"></div>
            <div class="Items-Grid">
                <div class="Item">
                    <img src="~/images/burger.png">
                    <h2>SALON BURGER</h2>
                    <p>המבורגר קלאסי עם כל הירקות ורוטב הבית</p>
                    <p class="price">₪55</p>
                    <button onclick="addItem('SALON BURGER', 55)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/crispy.png">
                    <h2>CHICKEN SALON</h2>
                    <p>המבורגר קריספי עם חזה עוף בטמפורה</p>
                    <p class="price">₪48</p>
                    <button onclick="addItem('CHICKEN SALON', 48)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/combo.webp">
                    <h2>COMBO SALON</h2>
                    <p>המבורגר גדול עם רצועות עוף קריספי</p>
                    <p class="price">₪62</p>
                    <button onclick="addItem('COMBO SALON', 62)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/antricot.png">
                    <h2>STEAK COMBO</h2>
                    <p>כריך אנטריקוט עם ירקות ואיולי שום</p>
                    <p class="price">₪59</p>
                    <button onclick="addItem('STEAK COMBO', 59)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/pita.png">
                    <h2>SALON MIX</h2>
                    <p>פיתה פרגית וקבב עם רוטב הבית</p>
                    <p class="price">₪45</p>
                    <button onclick="addItem('SALON MIX', 45)">הזמן</button>
                </div>
            </div>
        </section>

        <section class="Deals">
            <h1>שתייה</h1>
            <div class="line"></div>
            <div class="Items-Grid">
                <div class="Item">
                    <img src="~/images/water.jpg">
                    <h2>Water</h2>
                    <p>בקבוק מים</p>
                    <p class="price">₪8</p>
                    <button onclick="addItem('Water', 8)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/COLA.png">
                    <h2>COLA</h2>
                    <p>בקבוק קולה</p>
                    <p class="price">₪12</p>
                    <button onclick="addItem('COLA', 12)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/FUZETEA.png">
                    <h2>FUZE TEA</h2>
                    <p>בקבוק נסטי</p>
                    <p class="price">₪12</p>
                    <button onclick="addItem('FUZE TEA', 12)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/FANTA.jpg">
                    <h2>FANTA</h2>
                    <p>בקבוק פנטה</p>
                    <p class="price">₪12</p>
                    <button onclick="addItem('FANTA', 12)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/anavim.jpg">
                    <h2>GRAPE</h2>
                    <p>בקבוק ענבים</p>
                    <p class="price">₪12</p>
                    <button onclick="addItem('GRAPE', 12)">הזמן</button>
                </div>
            </div>
        </section>

        <section class="Deals">
            <h1>תוספות</h1>
            <div class="line"></div>
            <div class="Items-Grid">
                <div class="Item">
                    <img src="~/images/fries.png">
                    <h2>FRENCH FRIES</h2>
                    <p>צ'יפס קריספי חם ומלוח</p>
                    <p class="price">₪18</p>
                    <button onclick="addItem('FRENCH FRIES', 18)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/onionrings.png">
                    <h2>ONION RINGS</h2>
                    <p>טבעות בצל עם רוטב הבית</p>
                    <p class="price">₪22</p>
                    <button onclick="addItem('ONION RINGS', 22)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/wings.png">
                    <h2>CHICKEN WINGS</h2>
                    <p>כנפיים ברוטב צ'ילי פיקנטי</p>
                    <p class="price">₪28</p>
                    <button onclick="addItem('CHICKEN WINGS', 28)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/potatos.png">
                    <h2>POTATOES</h2>
                    <p>תפוחי אדמה קריספיים</p>
                    <p class="price">₪20</p>
                    <button onclick="addItem('POTATOES', 20)">הזמן</button>
                </div>
                <div class="Item">
                    <img src="~/images/salad.png">
                    <h2>SALAD</h2>
                    <p>סלט ירקות טרי עם שמן זית</p>
                    <p class="price">₪25</p>
                    <button onclick="addItem('SALAD', 25)">הזמן</button>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
    let cart = [];
    let total = 0;

    function addItem(name, price) {
        cart.push({ name, price });
        total += price;
        updateCart();
    }

    function updateCart() {
        const cartDiv = document.getElementById('cart-items');
        const totalSpan = document.getElementById('total-price');
        cartDiv.innerHTML = "";
        cart.forEach(item => {
            cartDiv.innerHTML += "<p>" + item.name + " - ₪" + item.price + "</p>";
        });
        totalSpan.innerText = total;
    }

function submitOrder() {
    const isLoggedIn = @Model.IsLoggedIn.ToString().ToLower();

    if (!isLoggedIn) {
        alert("עליך להתחבר למערכת כדי לבצע הזמנה!");
        window.location.href = "/Login"; 
        return;
    }

    const phone = document.getElementById('phone').value;
    const addr = document.getElementById('address').value;

    if (cart.length > 0 && phone && addr) {
        const itemsSummary = cart.map(i => i.name).join(", ");

        const orderData = {
            phone: phone,
            address: addr,
            items: itemsSummary,
            total: total
        };

        fetch('?handler=SubmitOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(orderData)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert("ההזמנה נשלחה!");
                cart = [];
                total = 0;
                updateCart();
            }
        });
    } else {
        alert("מלא פרטים!");
    }
}


</script>

</body>
</html>