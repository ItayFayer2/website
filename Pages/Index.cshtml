@page
@model IndexModel
@{
    ViewData["Title"] = "Burger Salon";
}

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/Site.css">
</head>

<body class="HomePage">

<div class="Hero">
    <video autoplay muted loop playsinline>
        <source src="~/videos/background.mp4" type="video/mp4">
    </video>
    <div class="Hero-Overlay">
        <h1 class="Glitch-Text">BURGER SALON</h1>
        <h3>ההמבורגר הכי טוב בגלקסיה</h3>
        <button class="Main-Btn">הזמן שולחן</button>
    </div>
</div>


<section class="Content-Section">
    <div class="Info-Row">
        <img class="Feature-Img" src="~/images/twoa.jpg">

        <div class="Text-Content">
            <h2>התפריט שלנו</h2>
            <p>
                כאן תוכלו למצוא מגוון המבורגרים, צ'יפס ותוספות.
                אנחנו משתמשים במוצרים טריים ומנסים לתת חוויה טעימה ופשוטה לכל אחד.
            </p>

            <button class="Main-Btn">לצפייה בתפריט</button>
        </div>
    </div>
    <div class="Info-Row Reverse">
        <img class="Feature-Img" src="~/images/onea.jpg">

        <div class="Text-Content">
            <h2>יצירת קשר</h2>
            <p>
                אם יש לכם שאלות או שאתם רוצים להזמין מקום,
                אפשר ליצור איתנו קשר ונשמח לעזור.
            </p>

            <button class="Main-Btn Alt">צור קשר</button>
        </div>
    </div>

</section>


</body>
</html>