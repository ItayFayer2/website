@page
@model BookModel

<link rel="stylesheet" href="~/css/Site.css" />

<div class="book-page">

    <h1>הזמנת שולחן</h1>

    <form method="post" class="book-form">

        <label>שם</label>
        <input type="text" name="Name" required />

        <label>תאריך</label>
        <input type="date" name="Date" required />

        <label>שעה</label>
        <input type="time" name="Time" required />

        <label>מספר אנשים</label>
        <input type="number" name="People" min="1" required />

        <button type="submit">הזמן שולחן</button>

    </form>

</div>

@if (TempData["Success"] != null)
{
    <script>
        alert("נקבע הזמנה לשולחן בשעה @TempData["Time"] בתאריך @TempData["Date"] עבור @TempData["People"] אנשים. תודה!");
    </script>
}